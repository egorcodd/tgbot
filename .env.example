BOT_TOKEN=123456:your-telegram-bot-token

# SQLite by default; swap to Postgres in prod, e.g.:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/tgbot
DATABASE_URL=sqlite+aiosqlite:///./bot.db

# Optional. If unset, FSM runs in process memory (fine for MVP).
# REDIS_URL=redis://localhost:6379/0

# Comma-separated Telegram user IDs allowed to use /broadcast and admin cmds
ADMIN_IDS=

# Link shown on the final screen
CLOSED_CHANNEL_URL=https://t.me/+your_invite_hash

# Optional file_id of the video-note (round video) sent on the final screen.
# Get it by sending the kruzhok to the bot once and using /getfileid as admin.
FINAL_VIDEO_NOTE_FILE_ID=

# TG message effect on the final card.
# Defaults to 🎉 confetti. Set to empty to disable.
# 🔥 5104841245755180586  ·  ❤️ 5159385139981059251  ·  👍 5107584321108051014
FINAL_EFFECT_ID=5046509860389126442

# Google Sheets live export (опционально)
# 1. Создать сервис-аккаунт в Google Cloud, скачать JSON-ключ
# 2. Поделиться Sheet'ом с email service account (Editor)
# 3. Положить JSON в secrets/ (папка уже в .gitignore)
GOOGLE_SHEET_ID=
GOOGLE_CREDENTIALS_PATH=secrets/gsheets.json
